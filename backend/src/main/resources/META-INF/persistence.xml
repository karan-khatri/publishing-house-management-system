<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">
    <persistence-unit name="default" transaction-type="JTA">
        <jta-data-source>java:jboss/datasources/PostgreSQLDS</jta-data-source>
        <!-- Add your entity classes here -->
        <class>org.swam.publishing_house.model.UserModel</class>
        <class>org.swam.publishing_house.model.RoleModel</class>
        <class>org.swam.publishing_house.model.AuthorModel</class>
        <class>org.swam.publishing_house.model.EmployeeModel</class>
        <class>org.swam.publishing_house.model.PublicationModel</class>

        <properties>
            <!-- Load initial data script -->
            <property name="jakarta.persistence.sql-load-script-source" value="META-INF/load.sql"/>

            <!-- Hibernate properties -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="create-drop"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
