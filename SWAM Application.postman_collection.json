					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Save token to collection variable\r",
									"const jsonData = pm.response.json();\r",
									"pm.collectionVariables.set(\"authToken\", jsonData.data.token);\r",
									"\r",
									"// Log success message\r",
									"console.log(\"Token saved:\", jsonData.token);"
